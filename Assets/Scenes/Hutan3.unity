  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InteractableObject
  dialogueLines:
  - text: Tolong aku, Orang Utan! Aku terkurung di dalam sangkar ini!
    speaker: Burung Kakak Tua
    portrait: {fileID: 4001931395401749380, guid: 6d03cb38aa4d0e6438573fd0f4f36eb6, type: 3}
  - text: Bagaimana cara membukanya?
    speaker: Bara
    portrait: {fileID: -6668896378578197248, guid: dc05296099fd74a4d94472e7d3817c5e, type: 3}
  - text: Kuncinya tertinggal di rompi proyek (vest) milik manusia di Hutan Awal!
      Tolong carikan!
    speaker: Burung Kakak Tua
    portrait: {fileID: 2319446498802120873, guid: 6d03cb38aa4d0e6438573fd0f4f36eb6, type: 3}
  useQuest: 1
  requiredQuest: 12
  nextQuest: 13
