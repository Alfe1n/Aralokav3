  m_EditorClassIdentifier: Assembly-CSharp::InteractableObject
  dialogueLines:
  - text: Terima kasih sudah menyelamatkanku, Orang Utan.
    speaker: Kudanil
    portrait: {fileID: 7062599076892770092, guid: b4e1d32305f99ea4d91f59bc11834810, type: 3}
  - text: Sekarang aku sudah bisa berkumpul lagi dengan yang lain di sini.
    speaker: Kudanil
    portrait: {fileID: -4383267846644541318, guid: b4e1d32305f99ea4d91f59bc11834810, type: 3}
  - text: Sama-sama. Senang melihatmu aman.
    speaker: Bara
    portrait: {fileID: 5319344114519903559, guid: dc05296099fd74a4d94472e7d3817c5e, type: 3}
