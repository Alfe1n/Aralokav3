  m_Script: {fileID: 11500000, guid: 8f4a2ab63b400b44f8c3f9a3691e0eb9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EventAreaTrigger
  triggerOnce: 1
  useInitialDelay: 0
  initialDelayDuration: 1
  useFadeIn: 0
  useFadeOut: 0
  cameraTarget: {fileID: 0}
