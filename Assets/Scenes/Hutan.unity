  useSmoothPan: 1
  panSpeed: 5
  playerWalkTarget: {fileID: 0}
  playerWalkStopDistance: 0.15
  movePlayerAtDialogIndex: -1
  useDialogue: 1
  dialogueLines:
  - text: Dimana ini..?
    speaker: Bara
    portrait: {fileID: 7933640903824198564, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: Hutan?
    speaker: Bara
    portrait: {fileID: 7933640903824198564, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: ...
    speaker: Bara
    portrait: {fileID: -450121407816647630, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: Aku menjadi orang utan?
    speaker: Bara
    portrait: {fileID: 5319344114519903559, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: Apa yang sebenarnya terjadi??
    speaker: Bara
    portrait: {fileID: -6668896378578197248, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: Apakah ini mimpi??
    speaker: Bara
    portrait: {fileID: -6668896378578197248, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: '!!!'
    speaker: Bara
    portrait: {fileID: 5319344114519903559, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  - text: Siapa itu?!
    speaker: Bara
    portrait: {fileID: 5319344114519903559, guid: d41cf00244fce9c4aabf92e25b57b398, type: 3}
  moveCameraAtDialogIndex: -1
  returnCameraAtDialogIndex: 99
  useQuest: 0
  requiredQuest: 3
  nextQuest: 3
  triggerOncePersistent: 1
  customPersistentKey: 
