  movePlayerAtDialogIndex: -1
  useDialogue: 1
  dialogueLines:
  - text: Hoam..
    speaker: Bara
    portrait: {fileID: 5796402981298746748, guid: 1e009e4812a5f3b47ac1a20460f7c9d4, type: 3}
  - text: Aku kebangun ya..
    speaker: Bara
    portrait: {fileID: 1979321724376584997, guid: 1e009e4812a5f3b47ac1a20460f7c9d4, type: 3}
  - text: Tempat ini terasa asing... namun anehnya terasa sangat tenang.
    speaker: Bara
    portrait: {fileID: 248901697488008595, guid: 1e009e4812a5f3b47ac1a20460f7c9d4, type: 3}
  - text: Aku capek, ngantuk banget
    speaker: Bara
    portrait: {fileID: 1979321724376584997, guid: 1e009e4812a5f3b47ac1a20460f7c9d4, type: 3}
